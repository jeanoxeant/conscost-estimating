@page "/projects"
@attribute [Authorize]

@using ConstructionCostEstimator.Data
@using ConstructionCostEstimator.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Projects</PageTitle>

<div class="projects-dashboard">
    <div class="projects-hero card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <p class="text-uppercase fw-semibold mb-2 text-white-50">Project dashboard</p>
                    <h1 class="display-6 fw-bold mb-2">Manage your construction projects</h1>
                    <p class="mb-0 text-white-50">Track estimates, budgets, and next steps from one central workspace.</p>
                </div>

                <button class="btn btn-light text-primary fw-semibold" @onclick="NavigateToCreate">
                    <i class="bi bi-plus-circle me-2"></i>Create Project
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-md-4">
            <div class="project-stat card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-label">Total projects</div>
                    <div class="stat-value">@projects.Count</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="project-stat card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-label">Active</div>
                    <div class="stat-value">@activeProjects</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="project-stat card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-label">Planned</div>
                    <div class="stat-value">@plannedProjects</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <div>
            <h2 class="h4 mb-1">Recent projects</h2>
            <p class="text-muted mb-0">Open a project to review its estimate details and progress.</p>
        </div>
    </div>

    @if (!projects.Any())
    {
        <div class="projects-empty card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <h3 class="h5 mb-2">No projects yet</h3>
                <p class="text-muted mb-4">Start by creating your first project and building the estimate around it.</p>
                <button class="btn btn-primary" @onclick="NavigateToCreate">
                    Create your first project
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var project in projects)
            {
                <div class="col-lg-6">
                    <div class="project-card card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <span class="badge @GetStatusBadgeClass(project.Status)">@project.Status</span>
                                        <span class="text-muted small">Project #@project.Id</span>
                                    </div>
                                    <h3 class="h5 mb-2">@project.Name</h3>
                                    <p class="text-muted mb-0">@(string.IsNullOrWhiteSpace(project.Description) ? "Add a short description to capture the project scope." : project.Description)</p>
                                </div>
                                <span class="status-indicator @GetStatusClass(project.Status)"></span>
                            </div>

                            <div class="row g-3 mt-2">
                                <div class="col-6">
                                    <div class="project-stat-inline">
                                        <div class="label">Estimated cost</div>
                                        <div class="value">@project.EstimatedCost.ToString("C")</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="project-stat-inline">
                                        <div class="label">Start date</div>
                                        <div class="value">@(project.StartDate == default ? "TBD" : project.StartDate.ToShortDateString())</div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-4">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => NavigateToEdit(project.Id)">
                                    Edit Project
                                </button>
                                <button class="btn btn-outline-secondary btn-sm">
                                    View Details
                                </button>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => ShowDeleteConfirmation(project)">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (selectedProject != null)
{
    <div class="card border-danger mt-4 shadow-sm">
        <div class="card-header bg-danger text-white">
            Delete Project
        </div>

        <div class="card-body">
            <p>
                You are about to permanently delete
                <strong>@selectedProject.Name</strong>.
            </p>

            <p class="text-danger">
                This action cannot be undone.
            </p>

            <p>
                Type <strong>DELETE</strong> to confirm.
            </p>

            <InputText class="form-control"
                       @bind-Value="confirmationText" />

            <div class="mt-3">
                <button class="btn btn-danger"
                        disabled="@(confirmationText != "DELETE")"
                        @onclick="DeleteProject">
                    Delete Permanently
                </button>

                <button class="btn btn-secondary ms-2"
                        @onclick="CancelDelete">
                    Cancel
                </button>
            </div>
        </div>
    </div>
}

@code
{
    private List<Project> projects = new();

    private Project? selectedProject;

    private string confirmationText = "";

    private int activeProjects => projects.Count(p => p.Status == ProjectStatus.Active);
    private int plannedProjects => projects.Count(p => p.Status == ProjectStatus.Planned);

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
            return;

        projects = await Db.Projects
            .Where(p => p.ApplicationUserId == user.Id)
            .OrderBy(p => p.Name)
            .ToListAsync();
    }

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/projects/create");
    }

    private void NavigateToEdit(int projectId)
    {
        Navigation.NavigateTo($"/projects/edit/{projectId}");
    }

    private string GetStatusBadgeClass(ProjectStatus status) => status switch
    {
        ProjectStatus.Active => "bg-primary",
        ProjectStatus.Completed => "bg-success",
        ProjectStatus.OnHold => "bg-warning text-dark",
        ProjectStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetStatusClass(ProjectStatus status) => status switch
    {
        ProjectStatus.Active => "status-active",
        ProjectStatus.Completed => "status-completed",
        ProjectStatus.OnHold => "status-onhold",
        ProjectStatus.Cancelled => "status-cancelled",
        _ => "status-planned"
    };

    private void ShowDeleteConfirmation(Project project)
    {
        selectedProject = project;
        confirmationText = "";
    }

    private void CancelDelete()
    {
        selectedProject = null;
        confirmationText = "";
    }

    private async Task DeleteProject()
    {
        if (selectedProject == null || confirmationText != "DELETE")
            return;

        // Get the tracked entity from the database
        var project = await Db.Projects.FirstOrDefaultAsync(p =>
            p.Id == selectedProject.Id &&
            p.ApplicationUserId == selectedProject.ApplicationUserId);

        if (project == null)
            return;

        // Delete the project
        Db.Projects.Remove(project);

        // Save changes to the database
        await Db.SaveChangesAsync();

        // Refresh the project list
        await LoadProjects();

        // Reset the confirmation dialog
        selectedProject = null;
        confirmationText = "";
    }
}