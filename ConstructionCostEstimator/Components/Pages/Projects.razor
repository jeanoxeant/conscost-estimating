@page "/projects"
@attribute [Authorize]

@using ConstructionCostEstimator.Data
@using ConstructionCostEstimator.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Projects</PageTitle>

<h1>Projects</h1>

@if (!projects.Any())
{
    <div class="alert alert-info">
        No projects found.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Estimated Cost</th>
                <th>Start Date</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var project in projects)
            {
                <tr>
                    <td>@project.Name</td>
                    <td>@project.Status</td>
                    <td>@project.EstimatedCost.ToString("C")</td>
                    <td>@project.StartDate.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => ShowDeleteConfirmation(project)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (selectedProject != null)
{
    <div class="card border-danger mt-4">
        <div class="card-header bg-danger text-white">
            Delete Project
        </div>

        <div class="card-body">

            <p>
                You are about to permanently delete
                <strong>@selectedProject.Name</strong>.
            </p>

            <p class="text-danger">
                This action cannot be undone.
            </p>

            <p>
                Type <strong>DELETE</strong> to confirm.
            </p>

            <InputText class="form-control"
                       @bind-Value="confirmationText" />

            <div class="mt-3">

                <button class="btn btn-danger"
                        disabled="@(confirmationText != "DELETE")"
                        @onclick="DeleteProject">
                    Delete Permanently
                </button>

                <button class="btn btn-secondary ms-2"
                        @onclick="CancelDelete">
                    Cancel
                </button>

            </div>

        </div>
    </div>
}

@code
{
    private List<Project> projects = new();

    private Project? selectedProject;

    private string confirmationText = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
            return;

        projects = await Db.Projects
            .Where(p => p.ApplicationUserId == user.Id)
            .OrderBy(p => p.Name)
            .ToListAsync();
    }

    private void ShowDeleteConfirmation(Project project)
    {
        selectedProject = project;
        confirmationText = "";
    }

    private void CancelDelete()
    {
        selectedProject = null;
        confirmationText = "";
    }

    private async Task DeleteProject()
    {
        if (selectedProject == null || confirmationText != "DELETE")
            return;

        // Get the tracked entity from the database
        var project = await Db.Projects.FirstOrDefaultAsync(p =>
            p.Id == selectedProject.Id &&
            p.ApplicationUserId == selectedProject.ApplicationUserId);

        if (project == null)
            return;

        // Delete the project
        Db.Projects.Remove(project);

        // Save changes to the database
        await Db.SaveChangesAsync();

        // Refresh the project list
        await LoadProjects();

        // Reset the confirmation dialog
        selectedProject = null;
        confirmationText = "";
    }
}