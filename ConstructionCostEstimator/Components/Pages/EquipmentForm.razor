@using ConstructionCostEstimator.Models

<EditForm Model="EquipmentModel" OnValidSubmit="Save">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row">

        <div class="col-md-4">
            <label>Equipment</label>
            <InputText class="form-control"
                       @bind-Value="EquipmentModel.Name" />
        </div>

        <div class="col-md-2">
            <label>Days</label>
            <InputNumber class="form-control"
                         @bind-Value="EquipmentModel.Days" />
        </div>

        <div class="col-md-3">
            <label>Daily Rate</label>
            <InputNumber class="form-control"
                         @bind-Value="EquipmentModel.DailyRate" />
        </div>

        <div class="col-md-3 d-grid">
            <label>&nbsp;</label>

            <button class="btn btn-success" type="submit">
                Save
            </button>
        </div>

    </div>

</EditForm>

@code {

    [Parameter]
    public Equipment EquipmentModel { get; set; } = new();

    [Parameter]
    public EventCallback<Equipment> OnSave { get; set; }

    private async Task Save()
    {
        await OnSave.InvokeAsync(EquipmentModel);
    }

}