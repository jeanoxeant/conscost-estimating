@page "/labor"

<PageTitle>Labor</PageTitle>

<h3>Labor Cost Estimator</h3>

<div class="card p-4 shadow-sm">

    <div class="mb-3">
        <label class="form-label">Trade / Employee</label>
        <input class="form-control" @bind="newLabor.Description" />
    </div>

    <div class="mb-3">
        <label class="form-label">Hours</label>
        <InputNumber class="form-control" @bind-Value="newLabor.Hours" />
    </div>

    <div class="mb-3">
        <label class="form-label">Hourly Rate ($)</label>
        <InputNumber class="form-control" @bind-Value="newLabor.HourlyRate" />
    </div>

    <button class="btn btn-primary" @onclick="AddLabor">
        Add Labor
    </button>

</div>

<hr />

@if (laborItems.Count > 0)
{
    <table class="table table-striped">

        <thead>
            <tr>
                <th>Description</th>
                <th>Hours</th>
                <th>Hourly Rate</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>

        <tbody>

        @foreach (var item in laborItems)
        {
            <tr>

                <td>@item.Description</td>

                <td>@item.Hours</td>

                <td>@item.HourlyRate.ToString("C")</td>

                <td>@item.TotalCost.ToString("C")</td>

                <td>
                    <button class="btn btn-danger btn-sm"
                            @onclick="() => DeleteLabor(item)">
                        Delete
                    </button>
                </td>

            </tr>
        }

        </tbody>

    </table>

    <h4 class="text-end">
        Total Labor Cost:
        <span class="text-success">
            @TotalLaborCost.ToString("C")
        </span>
    </h4>
}
else
{
    <p>No labor items added yet.</p>
}

@code {

    public class LaborItem
    {
        public string Description { get; set; } = "";

        public decimal Hours { get; set; }

        public decimal HourlyRate { get; set; }

        public decimal TotalCost => Hours * HourlyRate;
    }

    private LaborItem newLabor = new();

    private List<LaborItem> laborItems = new();

    private decimal TotalLaborCost =>
        laborItems.Sum(x => x.TotalCost);

    private void AddLabor()
    {
        if (string.IsNullOrWhiteSpace(newLabor.Description))
            return;

        if (newLabor.Hours <= 0)
            return;

        if (newLabor.HourlyRate <= 0)
            return;

        laborItems.Add(new LaborItem
        {
            Description = newLabor.Description,
            Hours = newLabor.Hours,
            HourlyRate = newLabor.HourlyRate
        });

        newLabor = new LaborItem();
    }

    private void DeleteLabor(LaborItem item)
    {
        laborItems.Remove(item);
    }

}